{
  "language": "German",
  "personality": "You are a friendly AI assistant for your user. Always talk to your user directly. There is no need to greet you user every single time. Don't be too wordy. NEVER make things up.",
  "assistant_name": "Lilly",
  "user_name": "Chloe",
  "log_level": "INFO",
  "modules": [
    "Email",
    "Weather",
    "EmailStatus",
    "Ollama",
    "OpenAICompat",
    "Matrix",
    "MQTTLights",
    "CoreMemory",
    "WebSearch",
    "Messenger",
    "CalDAV",
    "Timing",
    "ParcelTracking",
    "ParcelStatus"
  ],

  "module_configs": {
    "Email": {
      "imap_host": "imap.example.com",
      "imap_user": "user@example.com",
      "imap_password": "p455w0rd"
    },
    "Weather": {
      "latitude": 48.78,
      "longitude": 9.18,
      "location_name": "Stuttgart"
    },
    "EmailStatus": {
      "imap_host": "imap.example.com",
      "imap_user": "user@example.com",
      "imap_password": "p455w0rd"
    },
    "Ollama": {
      "ollama_endpoint": "http://ai.example.com:11434/api",
      "ollama_model": "qwen3:14b",
      "context_database": "ollama-context.sqlite",
      "short_term_memory_minutes": 960
    },
    "OpenAICompat": {
      "endpoint": "http://localhost:8080",
      "model": "mlx-community/Qwen3-14B-4bit",
      "context_database": "openai-compat-context.sqlite",
      "short_term_memory_minutes": 960
    },
    "CalDAV": {
      "calendars": [
        {
          "topic": "Birthdays",
          "url": "https://example.com/dav/birthdays/",
          "username": "user",
          "password": "p455w0rd"
        }]
    },
    "Timing": {
      "timing_database": "timing.sqlite"
    },
    "ParcelTracking": {
      "parcel_database": "parcels.sqlite",
      "dhl_api_key": "your-dhl-api-key",
      "poll_minutes": 30
    },
    "ParcelStatus": {
      "parcel_database": "parcels.sqlite"
    },
    "CoreMemory": {
      "memory_database": "core-memories.sqlite"
    },
    "WebSearch": {
      "searxng_endpoint": "http://localhost:8888",
      "max_results": 5
    },
    "Messenger": {
      "matrix_homeserver": "https://example.com",
      "matrix_token": "syt_xxx",
      "drafts_room_id": "!draftsroom:example.com"
    },
    "Matrix": {
      "matrix_homeserver": "https://example.com",
      "matrix_user": "@lilly:example.com",
      "matrix_password": "p455w0rd",
      "matrix_dm_room_id": "!roomid:example.com"
    },
    "MQTTLights": {
      "mqtt_broker": "mqtt.example.com",
      "mqtt_port": 1883,
      "lights": [{
        "name": "Living Room",
        "topic": "flat/livingroom/occupancy",
        "commands": {
          "on": "ON",
