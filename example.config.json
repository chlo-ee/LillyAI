{
  "language": "German",
  "personality": "You are a friendly AI assistant for your user. Always talk to your user directly. There is no need to greet you user every single time. Don't be too wordy. NEVER make things up.",
  "assistant_name": "Lilly",
  "user_name": "Chloe",
  "log_level": "INFO",
  "modules": [
    "Email",
    "Weather",
    "EmailStatus",
    "Ollama",
    "OpenAICompat",
    "Matrix",
    "MQTTLights",
    "CoreMemory",
    "WebSearch",
    "Messenger",
    "CalDAV",
    "Timing"
  ],

  "module_configs": {
    "Email": {
